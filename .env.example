# =========================
# Sutra repo environment
# =========================
# These variables are used by THIS repo:
# - CLI pipelines (python -m pipelines.full_index / incremental_update)
# - frontend/api FastAPI server (make ui-run)

# Required: PostgreSQL URL for AGE + pgvector writes.
SUTRA_PG_URL=postgresql://postgres:postgers@localhost:5433/postgres

# Required only when config/sutra.yaml has: embedder.provider: openai
OPENAI_API_KEY=sk-your-key-here

# Optional: override embedding price used for cost estimates in UI/logs.
# Unit: USD per 1,000,000 tokens. Example for text-embedding-3-small: 0.02
SUTRA_EMBED_COST_PER_1M_TOKENS=0.02


# =========================
# Target repository being indexed
# =========================
# The repo URL you submit in UI/CLI does not need its own .env file.
# Sutra clones public repos directly and runs analysis against local checkout.
